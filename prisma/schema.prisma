generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id        String   @id @default(uuid())
  name      String
  isActive  Boolean  @default(true)
  balance   Float    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users           User[]
  lineChannels    LineChannel[]
  customers       Customer[]
  conversations   Conversation[]
  products        Product[]
  productVariants ProductVariant[]
  orderDrafts     OrderDraft[]
  orderDraftItems OrderDraftItem[]
  orders          Order[]
  orderItems      OrderItem[]
  notificationTargets NotificationTarget[]
  storeSettings   StoreSetting[]
  auditLogs       AuditLog[]
  subscriptions   Subscription[]
  balanceTransactions BalanceTransaction[]
}

model Plan {
  id           String   @id @default(uuid())
  name         String
  price        Float
  orderLimit   Int      @default(0)
  channelLimit Int      @default(1)
  features     Json     @default("{}")
  isDefault    Boolean  @default(false)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  subscriptions Subscription[]
  @@index([isActive])
}

model Subscription {
  id         String   @id @default(uuid())
  tenantId   String   @unique
  planId     String
  status     String   @default("active")
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plan   Plan   @relation(fields: [planId], references: [id])
  @@index([tenantId])
  @@index([expiresAt])
}

model BalanceTransaction {
  id          String   @id @default(uuid())
  tenantId    String
  amount      Float
  type        String
  description String?
  createdAt   DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  @@index([tenantId, createdAt])
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String
  role         String
  tenantId     String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant        Tenant?    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  confirmedOrders Order[]
  auditLogs     AuditLog[]
}

model LineChannel {
  id                String    @id @default(uuid())
  tenantId          String    @unique
  channelId         String    @unique
  channelSecret     String
  channelAccessToken String
  webhookUrl        String?
  webhookEnabled    Boolean   @default(false)
  webhookVerifiedAt DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Customer {
  id              String   @id @default(uuid())
  tenantId        String
  lineUserId      String   @unique
  lineDisplayName String?
  linePictureUrl  String?
  name            String?
  phone           String?
  address         String?
  pendingInfoUpdate String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  conversations Conversation[]
  orderDrafts   OrderDraft[]
  orders        Order[]

  @@index([tenantId, lineUserId])
}

model Conversation {
  id        String   @id @default(uuid())
  tenantId  String
  customerId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer Customer   @relation(fields: [customerId], references: [id], onDelete: Cascade)
  messages Message[]
  orderDrafts OrderDraft[]

  @@index([tenantId, customerId])
}

model Message {
  id             String   @id @default(uuid())
  conversationId String
  senderType     String
  content        String?
  rawPayload     String?
  imageUrl       String?
  imageBase64    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

model Product {
  id          String   @id @default(uuid())
  tenantId    String
  sku         String?
  name        String
  category    String?
  description String?
  basePrice   Float?
  imageUrl    String?
  imageKey    String?
  isActive    Boolean  @default(true)
  sourceType  String
  sourceRef   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant  Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  variants ProductVariant[]
  orderDraftItems OrderDraftItem[]
  orderItems      OrderItem[]
}

model ProductVariant {
  id          String   @id @default(uuid())
  tenantId    String
  productId   String
  variantSku  String?
  color       String?
  size        String?
  price       Float?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  product         Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  tenant         Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  orderDraftItems OrderDraftItem[]
  orderItems     OrderItem[]

  @@index([tenantId, productId])
}

model OrderDraft {
  id               String   @id @default(uuid())
  tenantId         String
  customerId       String
  conversationId   String
  status           String
  source           String   @default("line")
  llmConfidence    Float?
  needsHumanReview Boolean  @default(true)
  missingFields    String
  summaryForStaff  String?
  replySuggestion  String?
  rawLlMOutput     String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  tenant     Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer   Customer         @relation(fields: [customerId], references: [id], onDelete: Cascade)
  conversation Conversation   @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  items      OrderDraftItem[]
  order      Order?

  @@index([tenantId, status])
}

model OrderDraftItem {
  id              String   @id @default(uuid())
  tenantId        String
  orderDraftId    String
  matchedProductId String?
  matchedVariantId String?
  rawText         String?
  name            String?
  color           String?
  size            String?
  quantity        Int?
  unitPrice       Float?
  isFuzzy         Boolean  @default(false)
  fuzzyReason     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  orderDraft     OrderDraft      @relation(fields: [orderDraftId], references: [id], onDelete: Cascade)
  matchedProduct Product?        @relation(fields: [matchedProductId], references: [id])
  matchedVariant ProductVariant? @relation(fields: [matchedVariantId], references: [id])
}

model Order {
  id                    String   @id @default(uuid())
  tenantId              String
  orderDraftId          String?  @unique
  conversationId        String?
  customerId            String
  status                String
  recipientName         String?
  recipientPhone        String?
  recipientAddress      String?
  deliveryMethod        String?
  deliveryNote          String?
  paymentMethod         String?
  paymentStatus         String?
  paymentLastFiveDigits String?
  paymentNote          String?
  staffNote            String?
  confirmedByUserId     String?
  confirmedAt           DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  orderDraft   OrderDraft?  @relation(fields: [orderDraftId], references: [id])
  customer     Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  confirmedBy  User?        @relation(fields: [confirmedByUserId], references: [id])
  items        OrderItem[]

  @@index([tenantId, status])
  @@index([tenantId, createdAt])
}

model OrderItem {
  id              String   @id @default(uuid())
  tenantId        String
  orderId         String
  productId       String?
  variantId       String?
  rawText         String?
  name            String?
  color           String?
  size            String?
  quantity        Int?
  unitPrice       Float?
  lineTotal       Float?
  isFuzzy         Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant  Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  order   Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product?        @relation(fields: [productId], references: [id])
  variant ProductVariant? @relation(fields: [variantId], references: [id])
}

model NotificationTarget {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  lineUserId String?
  email      String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
}

model StoreSetting {
  id                  String   @id @default(uuid())
  tenantId            String   @unique
  storeName           String?
  paymentMethods      String
  deliveryMethods     String
  customerGreeting    String?
  orderConfirmTemplate String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id         String   @id @default(uuid())
  tenantId   String?
  userId     String?
  action     String
  entityType String?
  entityId   String?
  metadata   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
}

model ProcessedWebhookEvent {
  id          String   @id
  tenantId    String
  channelId   String
  processedAt DateTime @default(now())

  @@index([tenantId, processedAt])
}
