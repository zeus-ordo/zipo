# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/zipo?schema=public"

# Authentication
JWT_SECRET="change-this-to-a-secure-random-string-in-production"

# LINE Channel (from LINE Developers Console)
